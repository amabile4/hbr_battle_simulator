{
  "name": "hbr-battle-simulator",
  "version": "1.0.0",
  "description": "ヘブンバーンズレッド戦闘シミュレータ",
  "type": "module",
  "scripts": {
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "dev": "python3 -m http.server 8080",
    "analyze:migration": "node json/scripts/build_skill_migration_artifacts.mjs",
    "analyze:migration:delta": "node json/scripts/compare_migration_metrics.mjs",
    "analyze:migration:all": "npm run analyze:migration && npm run analyze:migration:delta"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "jsdom": "^28.1.0",
    "playwright": "^1.58.2",
    "vitest": "^4.1.9"
  }
}
