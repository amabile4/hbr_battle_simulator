{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hbr-battle-simulator.local/schema/new_skill_database.schema.json",
  "title": "HBR Skill Database (Raw-Driven)",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "counts", "legacyCompatible", "canonicalSkills"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[A-Za-z0-9._-]+)?$"
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "characters",
        "normalizedCharacters",
        "styles",
        "skills",
        "passives",
        "legacyCompatibleSkillRows",
        "conflictRows"
      ],
      "properties": {
        "characters": { "type": "integer", "minimum": 1 },
        "normalizedCharacters": { "type": "integer", "minimum": 1 },
        "styles": { "type": "integer", "minimum": 1 },
        "skills": { "type": "integer", "minimum": 1 },
        "passives": { "type": "integer", "minimum": 1 },
        "legacyCompatibleSkillRows": { "type": "integer", "minimum": 1 },
        "conflictRows": { "type": "integer", "minimum": 0 }
      }
    },
    "legacyCompatible": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metadata", "characters"],
      "properties": {
        "metadata": {
          "type": "object",
          "additionalProperties": false,
          "required": ["sourceVersion", "generatedAt", "characterCount", "totalSkills"],
          "properties": {
            "sourceVersion": { "type": "string" },
            "generatedAt": { "type": "string", "format": "date-time" },
            "characterCount": { "type": "integer", "minimum": 1 },
            "totalSkills": { "type": "integer", "minimum": 1 }
          }
        },
        "characters": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name", "cost", "type", "sourceSkillIds", "variantCount", "hasConflict"],
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "cost": { "type": "integer", "minimum": 0, "maximum": 99 },
                "type": { "type": "string", "enum": ["damage", "non_damage"] },
                "sourceSkillIds": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "integer", "minimum": 1 }
                },
                "variantCount": { "type": "integer", "minimum": 1 },
                "hasConflict": { "type": "boolean" }
              }
            }
          }
        }
      }
    },
    "canonicalSkills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "skillId",
          "name",
          "normalizedNameKey",
          "chara",
          "rawChara",
          "styleName",
          "styleId",
          "team",
          "spCost",
          "type",
          "consumeType",
          "maxLevel",
          "isRestricted",
          "source"
        ],
        "properties": {
          "skillId": { "type": "integer", "minimum": 1 },
          "name": { "type": "string", "minLength": 1 },
          "normalizedNameKey": { "type": "string", "minLength": 3 },
          "chara": { "type": "string", "minLength": 1 },
          "rawChara": { "type": "string", "minLength": 1 },
          "styleName": { "type": "string", "minLength": 1 },
          "styleId": { "type": "integer", "minimum": 1 },
          "team": { "type": "string", "minLength": 1 },
          "role": { "type": ["string", "null"] },
          "spCost": { "type": "integer", "minimum": 0, "maximum": 99 },
          "type": { "type": "string", "enum": ["damage", "non_damage"] },
          "consumeType": { "type": ["string", "null"] },
          "maxLevel": { "type": ["integer", "null"], "minimum": 0 },
          "isRestricted": { "type": ["integer", "null"], "minimum": 0, "maximum": 1 },
          "source": {
            "type": "object",
            "additionalProperties": false,
            "required": ["from", "inDate", "label"],
            "properties": {
              "from": { "const": "skills.json" },
              "inDate": { "type": ["string", "null"] },
              "label": { "type": ["string", "null"] }
            }
          }
        }
      }
    }
  }
}
