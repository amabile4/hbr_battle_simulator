#!/bin/sh
set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
REPO_ROOT=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)
CRG_BIN="$REPO_ROOT/.venv/bin/code-review-graph"

if [ ! -x "$CRG_BIN" ]; then
    echo "code-review-graph is not installed in $REPO_ROOT/.venv" >&2
    echo "Run: python3 -m venv .venv && .venv/bin/pip install code-review-graph" >&2
    exit 127
fi

cd "$REPO_ROOT"
exec "$CRG_BIN" "$@"
